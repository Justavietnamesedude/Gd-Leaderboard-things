<title>Demon List</title>

<style>
:root{
--bg:#0d0d0d;
--panel:#181818;
--accent:#ffae00;
--text:#ffffff;
--sub:#aaaaaa;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:var(--bg);
color:var(--text);
font-family:Arial, Helvetica, sans-serif;
}

header{
background:#111;
padding:25px;
border-bottom:3px solid var(--accent);
}

header h1{
color:var(--accent);
font-size:40px;
}

.container{
width:95%;
max-width:1500px;
margin:auto;
padding:20px;
}

.search{
width:100%;
padding:14px;
background:#1c1c1c;
color:white;
border:1px solid #444;
margin-bottom:20px;
}

.list-entry{
display:flex;
align-items:center;
justify-content:space-between;
background:var(--panel);
border-left:4px solid var(--accent);
margin-bottom:8px;
padding:15px;
}

.rank{
width:90px;
font-size:32px;
font-weight:bold;
color:var(--accent);
}

.main{
flex:1;
}

.level{
font-size:24px;
font-weight:bold;
}

.creator{
color:var(--sub);
margin-top:4px;
}

.badge{
display:inline-block;
padding:4px 8px;
margin-top:6px;
border-radius:4px;
font-size:12px;
font-weight:bold;
}

.extreme{background:#8b0000;}
.insane{background:#7a2cff;}
.hard{background:#ff6a00;}
.medium{background:#0066ff;}
.easy{background:#00aa44;}
.robtop{background:#00cccc;}

.score{
text-align:right;
min-width:140px;
}

.score-value{
font-size:28px;
font-weight:bold;
}

.points{
color:#ccc;
margin-top:4px;
}
</style>
</head>

